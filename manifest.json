{
  "manifest_version": 3,
  "name": "F&SCM Entity Browser",
  "version": "1.1.0",
  "description": "Browse, inspect, and query D365 Finance & Supply Chain Management data entities.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["https://*.operations.dynamics.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.operations.dynamics.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open F&SCM Entity Browser"
  }
}
